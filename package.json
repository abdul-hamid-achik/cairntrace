{
  "name": "cairntrace",
  "version": "1.6.0",
  "description": "Behavioral browser-spec layer for agent-in-session use",
  "type": "module",
  "license": "MIT",
  "bin": {
    "cairn": "./bin/cairn"
  },
  "files": [
    "bin",
    "src",
    "AGENTS.md",
    "CLAUDE.md",
    "SECURITY.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt src bin",
    "format:check": "oxfmt --check src bin",
    "typecheck": "tsc --noEmit",
    "verify": "bun run typecheck && bun run lint && bun run test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^12.1.0",
    "execa": "^9.5.1",
    "playwright": "^1.60.0",
    "yaml": "^2.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "oxfmt": "^0.4.0",
    "oxlint": "^1.0.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
