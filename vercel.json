{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vitepress",
  "bunVersion": "1.x",
  "installCommand": "bun install",
  "buildCommand": "bun run docs:build",
  "outputDirectory": "docs/.vitepress/dist",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/(.*)?", "destination": "/$1.html" }
  ]
}
